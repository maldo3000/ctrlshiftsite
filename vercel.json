{
  "headers": [
    {
      "source": "/assets/images/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, stale-while-revalidate=604800" }
      ]
    },
    {
      "source": "/academy/(.*)\\.(jpg|png|svg|woff2|js|css)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, stale-while-revalidate=604800" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/academy",
      "destination": "/academy/index.html"
    },
    {
      "source": "/academy/",
      "destination": "/academy/index.html"
    },
    {
      "source": "/rawclaw",
      "destination": "/rawclaw/index.html"
    },
    {
      "source": "/rawclaw/",
      "destination": "/rawclaw/index.html"
    },
    {
      "source": "/launch",
      "destination": "/index.html"
    },
    {
      "source": "/launch/",
      "destination": "/index.html"
    },
    {
      "source": "/sponsors",
      "destination": "/index.html"
    },
    {
      "source": "/sponsors/",
      "destination": "/index.html"
    },
    {
      "source": "/sponsors/login",
      "destination": "/index.html"
    },
    {
      "source": "/sponsors/login/",
      "destination": "/index.html"
    },
    {
      "source": "/sponsors/vol-9",
      "destination": "/index.html"
    },
    {
      "source": "/sponsors/vol-9/",
      "destination": "/index.html"
    }
  ]
}
